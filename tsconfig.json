{
    "compilerOptions": {
      "target": "ES6",
      "module": "commonjs",
      "outDir": "./dist",
      "rootDir": "./src",
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "strict": true,
      "typeRoots": ["./node_modules/@types", "src/types"],
      "types": []
    },
    "include": [
      "src/**/*.ts"
    ]
  }
  